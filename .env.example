# Copy to .env and fill in real values before running docker compose

# Server
SERVER_PORT=8080
DOCKER_IMAGE=your-dockerhub-username/crypto-bot:latest

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# BingX API
BINGX_API_KEY=your-bingx-api-key
BINGX_API_SECRET=your-bingx-api-secret

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# OpenRoute API
OPENROUTE_API_KEY=your-openroute-api-key

# BD PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=crypto_bot_db
