# Cryptocurrency Investment Advisor Bot — конфигурация окружения.
# ВНИМАНИЕ: файл содержит секреты. НЕ коммитить в Git (уже в .gitignore).

# ---------- Docker Hub ----------
# Имя образа, который будет pull'иться на сервере. Переопределите под свой
# аккаунт Docker Hub или приватный registry.
DOCKER_IMAGE=sergger/crypto-advisor-bot:latest

# На каком порту хоста светить HTTP API (внутри контейнера — 8080)
APP_HOST_PORT=8081

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=put-your-telegram-bot-token-here
TELEGRAM_CHAT_ID=put-your-telegram-chat-id-here

# ---------- OpenRoute (LLM) ----------
OPENROUTE_API_KEY=put-your-openroute-api-key-here

# ---------- Spring Security: HTTP Basic для /users и /admin/** ----------
# Логин и пароль администратора HTTP API. ОБЯЗАТЕЛЬНО поменяйте пароль.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-this-strong-password

# ---------- PostgreSQL ----------
POSTGRES_DB=crypto_bot_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=please-change-this-postgres-password

# ---------- RabbitMQ ----------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
